<div class="form sub-form horizontal-sub-form">
<table cellpadding="0" cellspacing="0">
  <%= render 'batch_create_form_horizontal_header', {columns: columns, record: records.first} %>

  <tbody id="<%= element_form_id action: form_action %>-content" class="multiple">
    <% first = true -%>
    <% records.each do |scope, record| %>
    <%= render 'batch_create_form_horizontal_record', {columns: columns, form_action: form_action, scope: "[#{scope}]", first: first, record: record} %>
    <% first = false -%>
    <% end -%>
  </tbody>
</table>
</div>
