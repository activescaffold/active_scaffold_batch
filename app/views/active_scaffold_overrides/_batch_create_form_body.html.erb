<%
  ol_attrs = {}
  ol_attrs[:id] = subsection_id unless local_assigns[:subsection_id].nil?
  ol_attrs[:style] = 'display: none;' if columns.collapsed
%>
<%= as_element :fields_container, class: 'form', **ol_attrs do %>
  <%= as_element :form_element, hidden_field_tag("batch_scope", (batch_scope || 'LISTED')) %>

  <% columns.each_column(for: @record) do |column| %>
    <% next unless column.association.nil? || column.association.belongs_to? %>

    <% column_css_class = column.css_class unless column.css_class.is_a?(Proc) %>
    <% renders_as = column_renders_as(column) %>
    <% if renders_as == :subsection -%>
      <%= as_element :form_subsection, class: column_css_class do %>
        <%= render_subsection(column, @record, scope, form_action) %>
      <% end %>
    <% elsif column.association.try(:readonly?) %>
      <% next %>
    <% else %>
      <%= as_element :form_element, class: column_css_class do %>
        <%= render 'batch_create_form_attribute', column: column, record: @record %>
      <% end -%>
    <% end -%>
  <% end -%>
<% end %>
